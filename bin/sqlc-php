#!/usr/bin/env php
<?php

declare(strict_types=1);

if (isset($GLOBALS['_composer_autoload_path'])) {
    define('PHPIBE_COMPOSER_INSTALL', $GLOBALS['_composer_autoload_path']);
    unset($GLOBALS['_composer_autoload_path']);
} else {
    foreach ([
        __DIR__ . '/../../autoload.php',
        __DIR__ . '/../vendor/autoload.php',
        __DIR__ . '/vendor/autoload.php',
    ] as $file) {
        if (file_exists($file)) {
            define('PHPIBE_COMPOSER_INSTALL', $file);
            break;
        }
    }
    unset($file);
}

require PHPIBE_COMPOSER_INSTALL;

// Load symfony/yaml shim if the real package is not installed
if (!class_exists('Symfony\\Component\\Yaml\\Yaml', false)) {
    $shimPath = __DIR__ . '/../vendor/symfony/yaml/Yaml.php';
    if (file_exists($shimPath)) {
        require_once $shimPath;
    }
}

// Load psr/log shim if not already available via composer autoload
if (!interface_exists('Psr\\Log\\LoggerInterface', false)) {
    $psrBase = __DIR__ . '/../vendor/psr/log/src/';
    foreach (['LoggerInterface', 'LogLevel', 'AbstractLogger', 'NullLogger'] as $cls) {
        $f = $psrBase . $cls . '.php';
        if (file_exists($f)) require_once $f;
    }
}

use SqlcPhp\Analyzer\QueryAnalyzer;
use SqlcPhp\Catalog\SchemaCatalog;
use SqlcPhp\Config\Config;
use SqlcPhp\Config\Target;
use SqlcPhp\Generator\EnumGenerator;
use SqlcPhp\Generator\InterfaceGenerator;
use SqlcPhp\Generator\ModelGenerator;
use SqlcPhp\Generator\QueryGenerator;
use SqlcPhp\Generator\ResultDtoGenerator;
use SqlcPhp\Parser\SchemaParser;
use SqlcPhp\Parser\QueryParser;
use SqlcPhp\Resolver\ColumnResolver;
use SqlcPhp\Resolver\ParamResolver;
use SqlcPhp\Resolver\ExpressionTypeResolver;
use SqlcPhp\Rewriter\SqlRewriter;
use SqlcPhp\TypeMapper\TypeMapperFactory;
use SqlcPhp\Version;
use SqlcPhp\Watcher;
use SqlcPhp\SchemaExtractor\SchemaExtractorFactory;

// ---------------------------------------------------------------------------
// Argument parsing
// ---------------------------------------------------------------------------
$args           = array_slice($argv, 1);
$verifyMode     = in_array('--verify',          $args, true);
$dryRun         = in_array('--dry-run',         $args, true);
$diffMode       = in_array('--diff',            $args, true);
$watchMode      = in_array('--watch',           $args, true);
$generateSchema = in_array('--generate-schema', $args, true);
$showVersion    = in_array('--version',         $args, true) || in_array('-v', $args, true);
$showHelp       = in_array('--help',            $args, true) || in_array('-h', $args, true);

// --interval=N  (milliseconds, default 500)
$pollInterval = 500;
// --schema-output=path (override schema output destination)
$schemaOutput = null;
foreach ($args as $arg) {
    if (preg_match('/^--interval=(\d+)$/', $arg, $m)) {
        $pollInterval = max(100, (int) $m[1]);
    }
    if (preg_match('/^--schema-output=(.+)$/', $arg, $m)) {
        $schemaOutput = $m[1];
    }
}

$args = array_values(array_filter($args, fn($a) => !in_array($a, [
    '--verify', '--dry-run', '--diff', '--watch', '--version', '-v',
    '--generate-schema', '--help', '-h',
]) && !str_starts_with($a, '--interval=') && !str_starts_with($a, '--schema-output=')));

$configPath = $args[0] ?? 'sqlc.yaml';

// --help / -h: print usage and exit
if ($showHelp) {
    echo Version::BANNER . "\n\n";
    echo <<<HELP
Usage:
  sqlc-php [options] [config]

Arguments:
  config                Path to sqlc.yaml (default: sqlc.yaml)

Options:
  -h, --help            Show this help message and exit
  -v, --version         Print version and exit

Code generation:
  (no flag)             Generate PHP files from schema and queries
  --dry-run             Print generated code to stdout, write nothing
  --diff                Show a unified diff of what would change, write nothing
  --verify              Exit 1 if generated files are out of date (CI mode)

Watch mode:
  --watch               Watch schema and query files for changes and regenerate
                        automatically. Press Ctrl+C to stop.
  --interval=N          Polling interval in milliseconds (default: 500, min: 100)
                        Example: --watch --interval=250

Schema extraction:
  --generate-schema     Connect to the configured database and write schema.sql
                        Requires a 'database:' block in sqlc.yaml
  --schema-output=PATH  Override the output path for --generate-schema
                        Default: the first schema: file in sqlc.yaml

Examples:
  sqlc-php sqlc.yaml
  sqlc-php --verify sqlc.yaml
  sqlc-php --dry-run sqlc.yaml
  sqlc-php --diff sqlc.yaml
  sqlc-php --watch sqlc.yaml
  sqlc-php --watch --interval=250 sqlc.yaml
  sqlc-php --generate-schema sqlc.yaml
  sqlc-php --generate-schema --schema-output=db/schema.sql sqlc.yaml
  sqlc-php --version

HELP;
    exit(0);
}

// --version: print and exit
if ($showVersion) {
    echo Version::BANNER . "\n";
    exit(0);
}

// ---------------------------------------------------------------------------
// --generate-schema: connect to DB and write schema.sql
// ---------------------------------------------------------------------------
if ($generateSchema) {
    echo "sqlc-php v" . Version::VERSION . " — schema extractor\n";
    echo "Config : {$configPath}\n\n";

    try {
        $config = Config::fromFile($configPath);
    } catch (\RuntimeException $e) {
        fwrite(STDERR, "Error: " . $e->getMessage() . "\n");
        exit(1);
    }

    // Determine which DatabaseConfig to use — per-target first, then global
    $dbCfg = $config->database;
    foreach ($config->targets as $target) {
        if ($target->database !== null) {
            $dbCfg = $target->database;
            break;
        }
    }

    if ($dbCfg === null) {
        fwrite(STDERR, "Error: No 'database:' block found in {$configPath}.\n");
        fwrite(STDERR, "Add a database connection to your config:\n\n");
        fwrite(STDERR, "  database:\n");
        fwrite(STDERR, "    dsn:      \"mysql:host=localhost;dbname=myapp;charset=utf8mb4\"\n");
        fwrite(STDERR, "    username: \"\${DB_USER}\"\n");
        fwrite(STDERR, "    password: \"\${DB_PASS}\"\n\n");
        exit(1);
    }

    $dsn  = $dbCfg->resolvedDsn();
    $user = $dbCfg->resolvedUsername();
    $pass = $dbCfg->resolvedPassword();

    echo "Connecting: {$dsn}\n";

    try {
        $pdo = new PDO($dsn, $user ?: null, $pass ?: null, [
            PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        ]);
    } catch (\PDOException $e) {
        fwrite(STDERR, "Connection failed: " . $e->getMessage() . "\n");
        fwrite(STDERR, "Check your DSN, username, and password (remember \${ENV_VAR} expansion).\n");
        exit(1);
    }

    // Detect engine from DSN prefix
    $engine = SchemaExtractorFactory::engineFromDsn($dsn);
    echo "Engine  : {$engine}\n";

    try {
        $extractor = SchemaExtractorFactory::create($engine);
        $schemaSql = $extractor->extract($pdo, $dbCfg);
    } catch (\RuntimeException $e) {
        fwrite(STDERR, "Extraction failed: " . $e->getMessage() . "\n");
        exit(1);
    }

    // Determine output path
    if ($schemaOutput !== null) {
        $outputPath = $schemaOutput;
    } elseif (is_string($config->schemas[0] ?? null)) {
        // Write to the first schema file declared in config
        $outputPath = $config->schemas[0];
    } else {
        $outputPath = 'schema.sql';
    }

    // Ensure parent directory exists
    $dir = dirname($outputPath);
    if ($dir !== '.' && !is_dir($dir)) {
        mkdir($dir, 0755, true);
    }

    file_put_contents($outputPath, $schemaSql);

    $tableCount = substr_count($schemaSql, 'CREATE TABLE');
    echo "\n✓ Schema written to: {$outputPath}\n";
    echo "  " . $tableCount . " table(s) extracted.\n";
    exit(0);
}

// ---------------------------------------------------------------------------
// Core generation function — runs one full pass and returns metadata
// ---------------------------------------------------------------------------

/**
 * Run one full generation pass.
 *
 * @return array{
 *   written:    int,
 *   toWrite:    array<string, string>,
 *   watchPaths: string[],
 *   error:      string|null,
 * }
 */
function runGeneration(
    string $configPath,
    bool   $verifyMode,
    bool   $dryRun,
    bool   $diffMode,
    bool   $silent = false,
): array {
    $result = [
        'written'    => 0,
        'toWrite'    => [],
        'watchPaths' => [$configPath],
        'error'      => null,
    ];

    try {
        $config = Config::fromFile($configPath);
    } catch (\RuntimeException $e) {
        $result['error'] = $e->getMessage();
        return $result;
    }

    // Collect watch paths: config + all schemas + all query files
    $result['watchPaths'] = array_unique(array_merge(
        [$configPath],
        $config->schemas,
        ...array_map(fn($t) => $t->queries, $config->targets),
    ));

    // Parse schema
    $schemaParser = new SchemaParser();
    $allSchemaSql = '';

    foreach ($config->schemas as $schemaFile) {
        if (!file_exists($schemaFile)) {
            $result['error'] = "Schema file not found: {$schemaFile}";
            return $result;
        }
        $allSchemaSql .= "\n" . (file_get_contents($schemaFile) ?: '');
        if (!$silent) echo "Schema : {$schemaFile}\n";
    }

    $tables  = $schemaParser->parse($allSchemaSql);
    $catalog = new SchemaCatalog(array_merge($tables, $config->virtualTables));

    if (!$silent) {
        echo "Schema : " . count($tables) . " table(s) — " . implode(', ', array_column($tables, 'name')) . "\n";
        if (!empty($config->virtualTables)) {
            echo "Virtual: " . count($config->virtualTables) . " virtual table(s) — " .
                 implode(', ', array_map(fn($t) => $t->name, $config->virtualTables)) . "\n";
        }
        echo "\n";
    }

    $allToWrite   = [];
    $totalWritten = 0;

    foreach ($config->targets as $i => $target) {
        $passLabel = count($config->targets) > 1
            ? " [target " . ($i + 1) . "/" . count($config->targets) . "]"
            : '';

        if (!$silent) echo "Target{$passLabel}: {$target->namespace} → {$target->out()}/\n";

        $queryParser = new QueryParser($target->language);
        $rawQueries  = [];

        foreach ($target->queries as $queryFile) {
            if (!file_exists($queryFile)) {
                $result['error'] = "Queries file not found: {$queryFile}";
                return $result;
            }
            $parsed     = $queryParser->parse(file_get_contents($queryFile) ?: '');
            $rawQueries = array_merge($rawQueries, $parsed);
            if (!$silent) echo "  Queries: " . count($parsed) . " query(ies) from {$queryFile}\n";
        }
        if (!$silent) echo "  Queries: " . count($rawQueries) . " total\n";

        $output  = $target->output;

        // Derive per-type namespaces — in string form all are the same;
        // in map form each type gets baseNamespace\LastPathSegment
        $nsQueries    = $output->namespaceFor('queries');
        $nsModels     = $output->namespaceFor('models');
        $nsDtos       = $output->namespaceFor('dtos');
        $nsEnums      = $output->namespaceFor('enums');
        $nsInterfaces = $output->namespaceFor('interfaces');
        $nsCriterias  = $output->namespaceFor('criterias');

        $enumGen       = new EnumGenerator($nsEnums, $target->language);
        $typeMapper    = TypeMapperFactory::create($target->engine, $target->typeOverrides, $enumGen);
        $paramResolver = new ParamResolver($catalog, $typeMapper);
        $exprResolver  = new ExpressionTypeResolver($catalog, $typeMapper);
        $colResolver   = new ColumnResolver($catalog, $typeMapper, $paramResolver, $exprResolver);
        $analyzer      = new QueryAnalyzer($paramResolver, $colResolver, $queryParser, new SqlRewriter(), $catalog);
        $queries       = $analyzer->analyze($rawQueries);

        $resultDtoGen = new ResultDtoGenerator($nsDtos, $typeMapper);

        // Extension trait scaffolding — activated by declaring `extensions:` in out:
        $extGen = $output->hasExtensions()
            ? new \SqlcPhp\Generator\ExtensionGenerator(
                $output->namespaceFor('extensions_models'),
                $output->namespaceFor('extensions_dtos'),
                $output->namespaceFor('extensions_enums'),
            )
            : null;
        $interfaceGen = $target->generateInterfaces ? new InterfaceGenerator($nsInterfaces) : null;
        $queryGen     = new QueryGenerator(
            $catalog, $typeMapper, $resultDtoGen, $nsQueries,
            $target->generateInterfaces, $interfaceGen,
            $target->preparedStatementCache,
            $target->classSuffix,
            dtosNamespace:     '',
            criteriasNamespace: $nsCriterias,
            scopedCriterias:    $target->scopedDtos,
        );
        $modelGen     = new ModelGenerator($catalog, $typeMapper, $queryParser, $nsModels);

        $toWrite      = [];
        $scaffoldWrite = [];  // Extension scaffolds — written once, never overwritten

        foreach ($catalog->all() as $table) {
            if ($table->virtual) continue;
            foreach ($table->columns as $col) {
                if (!$col->isEnum()) continue;
                $e = $enumGen->generate($table->name, $col, $extGen);
                $toWrite["{$e['className']}.php"] = ['type' => 'enums', 'label' => '[enum]   ', 'code' => $e['code']];
                if ($extGen !== null && isset($e['extension'])) {
                    $relPath = $e['extension']->relPath;
                    // Only add if not already collected (dedup — same enum on multiple queries)
                    if (!isset($scaffoldWrite[$relPath])) {
                        $scaffoldWrite[$relPath] = [
                            'type'  => 'extensions_enums',
                            'label' => '[ext-e]  ',
                            'ext'   => $e['extension'],
                        ];
                    }
                }
            }
        }

        $tablesUsed = array_unique(array_filter(array_column($queries, 'fromTable')));
        foreach ($tablesUsed as $tableName) {
            $tableDef = $catalog->getTable($tableName);
            if ($tableDef?->virtual) continue;
            $m = $modelGen->generate($tableName, $extGen);
            $toWrite["{$m['className']}.php"] = ['type' => 'models', 'label' => '[model]  ', 'code' => $m['code']];
            if ($extGen !== null && isset($m['extension'])) {
                $scaffoldWrite[$m['extension']->relPath] = [
                    'type'  => 'extensions_models',
                    'label' => '[ext-m]  ',
                    'ext'   => $m['extension'],
                ];
            }
        }

        // ── Embed collision detection + DTO generation ─────────────────────────
        //
        // When scoped_dtos: false (default), two @embed annotations with the
        // same class name but different column shapes would silently overwrite
        // each other. We detect this and abort with a clear error.
        //
        // When scoped_dtos: true, each query method gets its own subdirectory:
        //   DTOs/GetBillingDetails/BillingReserve.php
        //   DTOs/GetBillingWithDate/BillingReserve.php
        // Collisions are impossible in this mode.

        if (!$target->scopedDtos) {
            // Build registry: embedClassName → ['shape' => string, 'queryName' => string]
            $embedRegistry = [];
            foreach ($queries as $query) {
                if ($query->returnsModelDirectly || empty($query->resultColumns)) continue;
                if ($query->returns->value === ':exec') continue;
                foreach ($query->embeds as $embed) {
                    $embedCols = array_filter(
                        $query->resultColumns,
                        fn($c) => $embed->matches($c->alias),
                    );
                    $shape = implode(',', array_map(
                        fn($c) => $embed->stripPrefix($c->alias) . ':' . $c->phpType,
                        $embedCols,
                    ));
                    if (isset($embedRegistry[$embed->className])) {
                        $existing = $embedRegistry[$embed->className];
                        if ($existing['shape'] !== $shape) {
                            $lines   = [];
                            $lines[] = "Error: @embed class '{$embed->className}' is declared in " .
                                       "multiple queries with different column shapes.";
                            $lines[] = '';
                            $lines[] = "  {$existing['queryName']}  → {$existing['shape']}";
                            $lines[] = "  {$query->name}  → {$shape}";
                            $lines[] = '';
                            $lines[] = 'Solutions:';
                            $lines[] = "  1. Enable scoped_dtos: true in sqlc.yaml to isolate DTOs per query method.";
                            $lines[] = "     Each method gets its own subdirectory (e.g. DTOs/GetBilling/BillingReserve.php).";
                            $lines[] = "  2. Use distinct class names for each query:";
                            $lines[] = "       -- @embed {$embed->className}Details {$embed->prefix}  (in {$existing['queryName']})";
                            $lines[] = "       -- @embed {$embed->className}Alt {$embed->prefix}      (in {$query->name})";
                            $lines[] = "  3. Use the same columns in both queries if the same class is intended.";
                            fwrite(STDERR, implode(PHP_EOL, $lines) . PHP_EOL);
                            exit(1);
                        }
                    } else {
                        $embedRegistry[$embed->className] = [
                            'shape'     => $shape,
                            'queryName' => $query->name,
                        ];
                    }
                }
            }
        }

        // @dto name collision detection (existing behaviour)
        $dtoRegistry = [];
        foreach ($queries as $query) {
            if ($query->returnsModelDirectly || empty($query->resultColumns)) continue;
            if ($query->returns->value === ':exec') continue;
            $dtoName = $resultDtoGen->dtoClassName($query);
            $shape   = implode(',', array_map(fn($c) => $c->alias . ':' . $c->phpType, $query->resultColumns));
            if (isset($dtoRegistry[$dtoName]) && $dtoRegistry[$dtoName] !== $shape) {
                fwrite(STDERR, "Warning: @dto '{$dtoName}' is used by multiple queries with " .
                    "different column shapes. The last writer wins — verify the generated file.\n");
            }
            $dtoRegistry[$dtoName] = $shape;
        }

        foreach ($queries as $query) {
            if ($query->returnsModelDirectly || empty($query->resultColumns)) continue;
            if ($query->returns->value === ':exec') continue;
            $r = $resultDtoGen->generate($query, $target->scopedDtos, $extGen);

            if ($target->scopedDtos && $r['scopeSubdir'] !== null) {
                // Place DTO and embeds in DTOs/{MethodPascalCase}/
                $subdir = $r['scopeSubdir'];
                $toWrite["{$subdir}/{$r['className']}.php"] = ['type' => 'dtos', 'label' => '[dto]    ', 'code' => $r['code']];
                foreach ($r['embeds'] as $cls => ['className' => $ecls, 'code' => $ec]) {
                    $toWrite["{$subdir}/{$ecls}.php"] = ['type' => 'dtos', 'label' => '[embed]  ', 'code' => $ec];
                }
            } else {
                $toWrite["{$r['className']}.php"] = ['type' => 'dtos', 'label' => '[dto]    ', 'code' => $r['code']];
                foreach ($r['embeds'] as $cls => ['className' => $ecls, 'code' => $ec]) {
                    $toWrite["{$ecls}.php"] = ['type' => 'dtos', 'label' => '[embed]  ', 'code' => $ec];
                }
            }
            // Collect DTO extension scaffolds
            foreach ($r['extensions'] ?? [] as $relPath => $ext) {
                $scaffoldWrite[$relPath] = [
                    'type'  => 'extensions_dtos',
                    'label' => '[ext-d]  ',
                    'ext'   => $ext,
                ];
            }
        }

        foreach ($queryGen->generate($queries) as $key => ['className' => $cls, 'code' => $code, 'relPath' => $relPath]) {
            // Criteria classes (generated by @searchable) go to 'criterias' bucket
            $type  = str_ends_with($cls, 'Criteria') ? 'criterias' : 'queries';
            $label = $type === 'criterias' ? '[criteria]' : '[query]  ';
            // Use relPath as the key so scoped criteria land in subdirs
            $fileKey = str_ends_with($cls, 'Criteria') ? $relPath : "{$cls}.php";
            $toWrite[$fileKey] = ['type' => $type, 'label' => $label, 'code' => $code];
        }

        foreach ($queryGen->generateInterfaces($queries) as ['className' => $cls, 'code' => $code]) {
            $toWrite["{$cls}.php"] = ['type' => 'interfaces', 'label' => '[iface]  ', 'code' => $code];
        }

        // ── Determine which types are actually needed ──────────────────────
        $neededTypes = array_unique(array_column(array_values($toWrite), 'type'));

        // Validate that all needed types have a declared dir (map form only)
        try {
            $output->assertAllDeclared($neededTypes);
        } catch (\RuntimeException $e) {
            $result['error'] = "Target '{$target->namespace}': " . $e->getMessage();
            return $result;
        }

        // ── Route each file to its correct directory ───────────────────────
        foreach ($toWrite as $file => $entry) {
            $type    = $entry['type'];
            $dir     = $output->dirFor($type);

            // Inject `use` statements when any generated class lives in a
            // different namespace. This covers both map-form out: and
            // scoped_dtos: true (where DTOs get deeper namespaces).
            $code = $entry['code'];
            $needsInjection = $output->isMap() || $target->scopedDtos;
            if ($needsInjection) {
                $code = injectUseStatements($code, $entry, $toWrite, $output);
            }

            $allToWrite["{$dir}/{$file}"] = $code;
        }

        if (!$verifyMode && !$dryRun && !$diffMode) {
            foreach ($toWrite as $file => $entry) {
                $type     = $entry['type'];
                $dir      = $output->dirFor($type);
                $code     = $allToWrite["{$dir}/{$file}"];
                $label    = $entry['label'];
                $fullPath = "{$dir}/{$file}";
                $fileDir  = dirname($fullPath);

                if (!is_dir($fileDir) && !mkdir($fileDir, 0755, true)) {
                    $result['error'] = "Cannot create output directory: {$fileDir}";
                    return $result;
                }
                file_put_contents($fullPath, $code);
                if (!$silent) echo "  {$label}{$fullPath}\n";
                $totalWritten++;
            }

            // Scaffold files — write ONCE only (never overwrite user edits)
            foreach ($scaffoldWrite as $relPath => $entry) {
                $type     = $entry['type'];
                $dir      = $output->dirFor($type);
                $fullPath = "{$dir}/{$relPath}";
                $fileDir  = dirname($fullPath);

                // Skip if already exists — this is the core write-once guarantee
                if (file_exists($fullPath)) {
                    if (!$silent) echo "  {$entry['label']}{$fullPath} (exists — not overwritten)\n";
                    continue;
                }

                if (!is_dir($fileDir) && !mkdir($fileDir, 0755, true)) {
                    $result['error'] = "Cannot create output directory: {$fileDir}";
                    return $result;
                }
                file_put_contents($fullPath, $entry['ext']->scaffoldCode);
                if (!$silent) echo "  {$entry['label']}{$fullPath}\n";
                $totalWritten++;
            }
        }

        // In dry-run: show what scaffolds would be created
        if ($dryRun) {
            foreach ($scaffoldWrite as $relPath => $entry) {
                $type     = $entry['type'];
                $dir      = $output->dirFor($type);
                $fullPath = "{$dir}/{$relPath}";
                if (file_exists($fullPath)) continue; // would not be written
                if (!$silent) echo "  {$entry['label']}[new] {$fullPath}\n";
            }
        }

        if (!$silent) echo "\n";
    }

    $result['written']       = $totalWritten;
    $result['toWrite']       = $allToWrite;
    $result['scaffoldWrite'] = $scaffoldWrite ?? [];

    return $result;
}

// ---------------------------------------------------------------------------
// Use statement injector — called only in map form when namespaces differ
// ---------------------------------------------------------------------------

/**
 * Given a generated PHP file, inject missing `use` statements for any
 * class references that now live in a different namespace (because map-form
 * out: was used).
 *
 * Strategy: scan for unqualified class names that appear as return types,
 * parameter types, `new ClassName`, `ClassName::`, or `implements ClassName`
 * in the generated code. If that class name belongs to a different namespace,
 * inject the appropriate `use` statement after the existing namespace declaration.
 *
 * @param string                             $code
 * @param array{type:string,label:string,code:string} $entry
 * @param array<string,array{type:string,...}>  $allFiles  All files being generated
 * @param \SqlcPhp\Config\OutputConfig       $output
 */
function injectUseStatements(
    string $code,
    array  $entry,
    array  $allFiles,
    \SqlcPhp\Config\OutputConfig $output,
): string {
    $myType  = $entry['type'];
    $myNs    = $output->namespaceFor($myType);

    // If this file itself has a deeper namespace (scoped_dtos), use it
    if (preg_match('/^namespace\s+([\w\\\\]+);/m', $code, $nsMatch)) {
        $myNs = $nsMatch[1];
    }

    // Determine this file's own class name — it must never be imported.
    // A file declaring `readonly class ReserveBilling` cannot also have
    // `use App\Models\ReserveBilling` — PHP rejects duplicate short names.
    $myClassName = null;
    if (preg_match('/^(?:readonly\s+)?class\s+(\w+)/m', $code, $clsMatch)) {
        $myClassName = $clsMatch[1];
    }

    // Build a map: className → FQCN for all generated classes in OTHER namespaces.
    // For scoped DTO files, read the actual namespace from the generated code,
    // not from OutputConfig (which only knows the base DTO namespace).

    // First pass: collect all short names that already live in $myNs.
    // These are "siblings" — classes in the same namespace as this file.
    // A sibling class is always available without a `use` statement, so any
    // class from another namespace with the same short name must be skipped
    // (importing it would create a duplicate short-name conflict).
    $siblingNames = [];
    foreach ($allFiles as $fileName => $other) {
        $otherCode = $other['code'];
        $otherNs   = $output->namespaceFor($other['type']);
        if (preg_match('/^namespace\s+([\w\\\\]+);/m', $otherCode, $m)) {
            $otherNs = $m[1];
        }
        if ($otherNs !== $myNs) continue;
        $cls = basename($fileName, '.php');
        $siblingNames[$cls] = true;
    }

    $classToFqcn = [];
    foreach ($allFiles as $fileName => $other) {
        $otherCode = $other['code'];
        $otherNs   = $output->namespaceFor($other['type']);

        // Prefer the actual namespace declared in the file (handles scoped_dtos)
        if (preg_match('/^namespace\s+([\w\\\\]+);/m', $otherCode, $m)) {
            $otherNs = $m[1];
        }

        if ($otherNs === $myNs) continue;

        $cls = basename($fileName, '.php');

        // Never import a class whose short name equals this file's own class name.
        // e.g. readonly class ReserveBilling must not get `use ...\ReserveBilling`
        if ($cls === $myClassName) continue;

        // Never import a class whose short name is already taken by a sibling
        // in the same namespace. e.g. if Reserve.php exists in $myNs (as an embed),
        // don't inject `use Models\Reserve` even though the model has the same name.
        if (isset($siblingNames[$cls])) continue;

        $classToFqcn[$cls] = $otherNs . '\\' . $cls;
    }

    if (empty($classToFqcn)) return $code;

    // Find which of those classes are actually referenced in this file.
    // Strip namespace and use-statement lines — they contain class names as
    // string segments (e.g. namespace X\ReserveBilling\Y contains 'ReserveBilling'
    // as a namespace segment, not a type reference).
    // Also strip the `class ClassName` prefix — but KEEP the implements/extends
    // clause so we can detect interface references.
    $bodyOnly = preg_replace('/^namespace\s+[^;]+;\s*/m', '', $code) ?? $code;
    $bodyOnly = preg_replace('/^use\s+[^;]+;\s*/m', '', $bodyOnly) ?? $bodyOnly;
    // Strip ONLY "class ClassName" — not the implements/extends part
    $bodyOnly = preg_replace('/^(?:readonly\s+)?class\s+\w+/m', '', $bodyOnly) ?? $bodyOnly;

    $needed = [];
    foreach ($classToFqcn as $cls => $fqcn) {
        // Match class usage in the body (return type, param type, new X, X::, X $, etc.)
        if (preg_match('/\b' . preg_quote($cls, '/') . '\b/', $bodyOnly)) {
            $needed[$fqcn] = true;
        }
    }

    if (empty($needed)) return $code;

    // Remove any FQCNs that are already imported in the file.
    // CriteriaGenerator writes enum use statements itself; injectUseStatements
    // must not add a second copy.
    preg_match_all('/^use\s+([\w\\\\]+);/m', $code, $alreadyImported);
    $existingFqcns = array_flip($alreadyImported[1]);
    $needed = array_filter($needed, fn($_, $fqcn) => !isset($existingFqcns[$fqcn]), ARRAY_FILTER_USE_BOTH);

    if (empty($needed)) return $code;

    // Build use statements block
    $uses = implode("\n", array_map(fn($fqcn) => "use {$fqcn};", array_keys($needed)));

    // Inject after the `namespace ...;` line
    $code = preg_replace(
        '/^(namespace [^;]+;)/m',
        "$1\n\n{$uses}",
        $code,
        1
    ) ?? $code;

    return $code;
}


// ---------------------------------------------------------------------------
// --watch mode
// ---------------------------------------------------------------------------
if ($watchMode) {
    if ($verifyMode || $dryRun || $diffMode) {
        fwrite(STDERR, "Error: --watch cannot be combined with --verify, --dry-run, or --diff.\n");
        exit(1);
    }

    echo "sqlc-php v" . Version::VERSION . " — watching for changes\n";
    echo "Config : {$configPath}\n";
    echo "Press Ctrl+C to stop.\n\n";

    // Graceful shutdown on SIGINT (Ctrl+C) — only on platforms that support it
    if (function_exists('pcntl_signal')) {
        pcntl_signal(SIGINT, function () {
            echo "\n\nWatch mode stopped.\n";
            exit(0);
        });
    }

    $watcher = new Watcher([$configPath]);

    // Run first pass immediately
    $r = runGeneration($configPath, false, false, false, silent: false);
    if ($r['error'] !== null) {
        fwrite(STDERR, "[ERROR] " . $r['error'] . "\n\n");
    } else {
        echo "✓ " . $r['written'] . " file(s) written.\n\n";
        $watcher->setAll($r['watchPaths']);
    }

    $intervalUs = $pollInterval * 1000;

    while (true) {
        if (function_exists('pcntl_signal_dispatch')) {
            pcntl_signal_dispatch();
        }

        usleep($intervalUs);

        $changed = $watcher->poll();

        if (empty($changed)) {
            continue;
        }

        $timestamp = date('H:i:s');
        $changedStr = implode(', ', array_map('basename', $changed));
        echo "[{$timestamp}] Change detected: {$changedStr}\n";

        $r = runGeneration($configPath, false, false, false, silent: true);

        if ($r['error'] !== null) {
            fwrite(STDERR, "[{$timestamp}] Error: " . $r['error'] . "\n\n");
        } else {
            // Update watch list in case config/queries changed
            $watcher->setAll($r['watchPaths']);
            echo "[{$timestamp}] ✓ " . $r['written'] . " file(s) written.\n\n";
        }
    }
}

// ---------------------------------------------------------------------------
// Normal single-run mode
// ---------------------------------------------------------------------------
echo "sqlc-php v" . Version::VERSION . " — PHP code generator\n";
if ($verifyMode) echo "Mode   : VERIFY  (no files will be written)\n";
if ($dryRun)     echo "Mode   : DRY-RUN (no files will be written)\n";
if ($diffMode)   echo "Mode   : DIFF    (no files will be written)\n";
echo "Config : {$configPath}\n\n";

$r = runGeneration($configPath, $verifyMode, $dryRun, $diffMode);

if ($r['error'] !== null) {
    fwrite(STDERR, "Error: " . $r['error'] . "\n");
    exit(1);
}

$allToWrite   = $r['toWrite'];
$totalWritten = $r['written'];

// ---------------------------------------------------------------------------
// --verify
// ---------------------------------------------------------------------------
if ($verifyMode) {
    $diffs   = [];
    $missing = [];

    foreach ($allToWrite as $path => $code) {
        if (!file_exists($path))                          $missing[] = $path;
        elseif (file_get_contents($path) !== $code)       $diffs[]   = $path;
    }

    if (empty($diffs) && empty($missing)) {
        echo "✓ All " . count($allToWrite) . " generated file(s) are up to date.\n";
        exit(0);
    }

    fwrite(STDERR, "✗ Generated files are out of date.\n\n");
    if (!empty($missing)) {
        fwrite(STDERR, "Missing files (" . count($missing) . "):\n");
        foreach ($missing as $f) fwrite(STDERR, "  - {$f}\n");
    }
    if (!empty($diffs)) {
        fwrite(STDERR, "\nModified files (" . count($diffs) . "):\n");
        foreach ($diffs as $f) fwrite(STDERR, "  ~ {$f}\n");
    }
    fwrite(STDERR, "\nRun `php vendor/bin/sqlc-php {$configPath}` to regenerate.\n");
    exit(1);
}

// ---------------------------------------------------------------------------
// --dry-run
// ---------------------------------------------------------------------------
if ($dryRun) {
    foreach ($allToWrite as $path => $code) {
        echo str_repeat('─', 70) . "\n";
        echo "// {$path}\n";
        echo str_repeat('─', 70) . "\n";
        echo $code . "\n\n";
    }
    echo "✓ Dry run complete. " . count($allToWrite) . " file(s) would be written.\n";
    exit(0);
}

// ---------------------------------------------------------------------------
// --diff
// ---------------------------------------------------------------------------
if ($diffMode) {
    $hasChanges = false;

    foreach ($allToWrite as $path => $newCode) {
        $oldCode = file_exists($path) ? (file_get_contents($path) ?: '') : null;

        if ($oldCode === $newCode) continue;

        $hasChanges = true;

        if ($oldCode === null) {
            echo "\033[32m+++ {$path} (new file)\033[0m\n";
            foreach (explode("\n", $newCode) as $line) {
                echo "\033[32m+ {$line}\033[0m\n";
            }
        } else {
            echo "--- {$path} (current)\n";
            echo "+++ {$path} (generated)\n";
            echo produceDiff($oldCode, $newCode);
        }

        echo "\n";
    }

    if (!$hasChanges) {
        echo "✓ No changes. All " . count($allToWrite) . " generated file(s) are up to date.\n";
        exit(0);
    }

    exit(1);
}

// ---------------------------------------------------------------------------
// Normal mode summary
// ---------------------------------------------------------------------------
echo "Done. {$totalWritten} file(s) written.\n";

// ---------------------------------------------------------------------------
// Diff helper
// ---------------------------------------------------------------------------
function produceDiff(string $old, string $new): string
{
    $oldLines = explode("\n", $old);
    $newLines = explode("\n", $new);
    $output   = '';

    $firstDiff = null;
    $lastDiff  = 0;
    $max       = max(count($oldLines), count($newLines));

    for ($i = 0; $i < $max; $i++) {
        if (($oldLines[$i] ?? null) !== ($newLines[$i] ?? null)) {
            if ($firstDiff === null) $firstDiff = $i;
            $lastDiff = $i;
        }
    }

    if ($firstDiff === null) return '';

    $ctx   = 3;
    $start = max(0, $firstDiff - $ctx);
    $end   = min($max - 1, $lastDiff + $ctx);

    if ($start > 0) $output .= "@@ ... @@\n";

    for ($i = $start; $i <= $end; $i++) {
        $o = $oldLines[$i] ?? null;
        $n = $newLines[$i] ?? null;

        if ($o === $n) {
            $output .= "  {$o}\n";
        } else {
            if ($o !== null) $output .= "\033[31m- {$o}\033[0m\n";
            if ($n !== null) $output .= "\033[32m+ {$n}\033[0m\n";
        }
    }

    if ($end < $max - 1) $output .= "@@ ... @@\n";

    return $output;
}
