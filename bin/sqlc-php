#!/usr/bin/env php
<?php

declare(strict_types=1);

if (isset($GLOBALS['_composer_autoload_path'])) {
    define('PHPIBE_COMPOSER_INSTALL', $GLOBALS['_composer_autoload_path']);

    unset($GLOBALS['_composer_autoload_path']);
} else {
    foreach (array(__DIR__ . '/../../autoload.php', __DIR__ . '/../vendor/autoload.php', __DIR__ . '/vendor/autoload.php') as $file) {
        if (file_exists($file)) {
            define('PHPIBE_COMPOSER_INSTALL', $file);

            break;
        }
    }

    unset($file);
}

require PHPIBE_COMPOSER_INSTALL;

use SqlcPhp\Catalog\SchemaCatalog;
use SqlcPhp\Config\Config;
use SqlcPhp\Generator\ModelGenerator;
use SqlcPhp\Generator\QueryGenerator;
use SqlcPhp\Generator\ResultDtoGenerator;
use SqlcPhp\Parser\QueryParser;
use SqlcPhp\Parser\SchemaParser;
use SqlcPhp\Resolver\ColumnResolver;
use SqlcPhp\Resolver\ExpressionTypeResolver;
use SqlcPhp\Resolver\ParamResolver;
use SqlcPhp\TypeMapper\MySQLTypeMapper;
use SqlcPhp\Analyzer\QueryAnalyzer;

// ---------------------------------------------------------------------------
$configPath = $argv[1] ?? 'sqlc.yaml';
echo "sqlc-php — PHP code generator\n";
echo "Config : {$configPath}\n\n";

try {
    $config = Config::fromFile($configPath);
} catch (\RuntimeException $e) {
    fwrite(STDERR, "Error: " . $e->getMessage() . "\n"); exit(1);
}

// ---------------------------------------------------------------------------
// Parse schema
// ---------------------------------------------------------------------------
if (!file_exists($config->schema)) {
    fwrite(STDERR, "Error: Schema file not found: {$config->schema}\n"); exit(1);
}

$tables  = (new SchemaParser())->parse(file_get_contents($config->schema) ?: '');
$catalog = new SchemaCatalog($tables);
echo "Schema : " . count($tables) . " table(s) — " . implode(', ', array_column($tables, 'name')) . "\n";

// ---------------------------------------------------------------------------
// Parse queries
// ---------------------------------------------------------------------------
if (!file_exists($config->queries)) {
    fwrite(STDERR, "Error: Queries file not found: {$config->queries}\n"); exit(1);
}

$queryParser = new QueryParser();
$rawQueries  = $queryParser->parse(file_get_contents($config->queries) ?: '');
echo "Queries: " . count($rawQueries) . " query(ies) parsed\n\n";

// ---------------------------------------------------------------------------
// Analyze (resolve types)
// ---------------------------------------------------------------------------
$typeMapper    = new MySQLTypeMapper($config->typeOverrides);
$paramResolver = new ParamResolver($catalog, $typeMapper);
$exprResolver  = new ExpressionTypeResolver($catalog, $typeMapper);
$colResolver   = new ColumnResolver($catalog, $typeMapper, $paramResolver, $exprResolver);
$analyzer      = new QueryAnalyzer($paramResolver, $colResolver, $queryParser);
$queries       = $analyzer->analyze($rawQueries);

// ---------------------------------------------------------------------------
// Output directory
// ---------------------------------------------------------------------------
$outDir = rtrim($config->out, '/');
if (!is_dir($outDir) && !mkdir($outDir, 0755, true)) {
    fwrite(STDERR, "Error: Cannot create output directory: {$outDir}\n"); exit(1);
}

$written = 0;

// ---------------------------------------------------------------------------
// 1. Model classes (for tables used in queries returning model directly)
// ---------------------------------------------------------------------------
$modelGen   = new ModelGenerator($catalog, $typeMapper, $queryParser, $config->namespace);
$tablesUsed = array_unique(array_filter(array_column($queries, 'fromTable')));

foreach ($tablesUsed as $tableName) {
    ['className' => $cls, 'code' => $code] = $modelGen->generate($tableName);
    file_put_contents("{$outDir}/{$cls}.php", $code);
    echo "  [model]  {$outDir}/{$cls}.php\n";
    $written++;
}

// ---------------------------------------------------------------------------
// 2. Result DTOs (for queries with custom SELECT or JOINs)
// ---------------------------------------------------------------------------
$resultDtoGen = new ResultDtoGenerator($config->namespace);

foreach ($queries as $query) {
    if ($query->returnsModelDirectly || empty($query->resultColumns)) continue;
    if (in_array($query->returns->value, [':exec'])) continue;

    ['className' => $cls, 'code' => $code] = $resultDtoGen->generate($query);
    file_put_contents("{$outDir}/{$cls}.php", $code);
    echo "  [dto]    {$outDir}/{$cls}.php\n";
    $written++;
}

// ---------------------------------------------------------------------------
// 3. Query classes
// ---------------------------------------------------------------------------
$queryGen   = new QueryGenerator($catalog, $typeMapper, $resultDtoGen, $config->namespace);
$queryFiles = $queryGen->generate($queries);

foreach ($queryFiles as ['className' => $cls, 'code' => $code]) {
    file_put_contents("{$outDir}/{$cls}.php", $code);
    echo "  [query]  {$outDir}/{$cls}.php\n";
    $written++;
}

echo "\nDone. {$written} file(s) written to {$outDir}/\n";

// ---------------------------------------------------------------------------
// Debug summary
// ---------------------------------------------------------------------------
echo "\n── Query analysis ──────────────────────────────────────────\n";
foreach ($queries as $q) {
    $paramStr = empty($q->params)
        ? '(none)'
        : implode(', ', array_map(fn($p) => "{$p->phpType} \${$p->name}", $q->params));

    $retStr = $q->returnsModelDirectly
        ? $q->modelClass . ($q->returns->value === ':many' ? '[]' : '|null')
        : (empty($q->resultColumns) ? 'void' : $q->returns->name);

    echo "  {$q->name}()\n";
    echo "    params  : {$paramStr}\n";
    echo "    returns : {$retStr}\n";
    if (!empty($q->resultColumns)) {
        $cols = array_map(fn($c) => "{$c->phpType} \${$c->alias}", $q->resultColumns);
        echo "    columns : " . implode(', ', array_slice($cols, 0, 5));
        if (count($cols) > 5) echo ' … +' . (count($cols) - 5) . ' more';
        echo "\n";
    }
}
echo "────────────────────────────────────────────────────────────\n";
